{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rxxusp/local-engine-router/config.schema.json",
  "title": "local-engine-router configuration",
  "description": "Configuration schema for local-engine-router (local-engine-router). Unknown keys are accepted with a warning for forward compatibility.",
  "type": "object",
  "properties": {
    "host": {
      "type": "string",
      "default": "127.0.0.1"
    },
    "port": {
      "type": "integer",
      "default": 8077
    },
    "api_keys": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "log_file": {
      "type": "string",
      "default": "./logs/router.log"
    },
    "log_level": {
      "type": "string",
      "default": "INFO"
    },
    "state_file": {
      "type": "string",
      "default": "./state.json"
    },
    "swap_keepalive_interval_s": {
      "type": "number",
      "default": 5.0
    },
    "swap_keepalive_enabled": {
      "type": "boolean",
      "default": true
    },
    "drain_timeout_s": {
      "type": "number",
      "default": 30.0
    },
    "swap_memory_settle_timeout_s": {
      "type": "number",
      "default": 25.0
    },
    "upstream_connect_timeout_s": {
      "type": "number",
      "default": 15.0
    },
    "allow_destructive_ollama_api": {
      "type": "boolean",
      "default": false
    },
    "aliases": {
      "type": "object",
      "additionalProperties": true
    },
    "ds4": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "base_url": {
          "type": "string",
          "default": "http://172.17.0.1:8099"
        },
        "control": {
          "type": "string",
          "default": "systemd-user"
        },
        "systemd_user_unit": {
          "type": "string",
          "default": "ds4.service"
        },
        "serve_script": {
          "type": "string",
          "default": ""
        },
        "process_pattern": {
          "type": "string",
          "default": "ds4/ds4-server"
        },
        "health_path": {
          "type": "string",
          "default": "/v1/models"
        },
        "start_timeout_s": {
          "type": "number",
          "default": 240.0
        },
        "stop_timeout_s": {
          "type": "number",
          "default": 45.0
        },
        "log_file": {
          "type": "string",
          "default": "./logs/ds4-server.log"
        },
        "control_headers": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "ollama": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "base_url": {
          "type": "string",
          "default": "http://127.0.0.1:11434"
        },
        "health_path": {
          "type": "string",
          "default": "/api/tags"
        },
        "unload_timeout_s": {
          "type": "number",
          "default": 60.0
        },
        "systemd_unit": {
          "type": "string",
          "default": "ollama.service"
        },
        "tags_cache_ttl_s": {
          "type": "number",
          "default": 30.0
        },
        "control_headers": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "engines": {
      "type": "object",
      "description": "Optional generic engine table: engine_key -> engine settings. When present it is the sole source of engines and the ds4:/ollama: sections are ignored.",
      "additionalProperties": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "type": {
                "const": "ds4"
              },
              "enabled": {
                "type": "boolean",
                "default": true
              },
              "base_url": {
                "type": "string",
                "default": "http://172.17.0.1:8099"
              },
              "control": {
                "type": "string",
                "default": "systemd-user"
              },
              "systemd_user_unit": {
                "type": "string",
                "default": "ds4.service"
              },
              "serve_script": {
                "type": "string",
                "default": ""
              },
              "process_pattern": {
                "type": "string",
                "default": "ds4/ds4-server"
              },
              "health_path": {
                "type": "string",
                "default": "/v1/models"
              },
              "start_timeout_s": {
                "type": "number",
                "default": 240.0
              },
              "stop_timeout_s": {
                "type": "number",
                "default": 45.0
              },
              "log_file": {
                "type": "string",
                "default": "./logs/ds4-server.log"
              },
              "control_headers": {
                "type": "object",
                "additionalProperties": true
              }
            },
            "additionalProperties": true,
            "required": [
              "type"
            ]
          },
          {
            "type": "object",
            "properties": {
              "type": {
                "const": "ollama"
              },
              "enabled": {
                "type": "boolean",
                "default": true
              },
              "base_url": {
                "type": "string",
                "default": "http://127.0.0.1:11434"
              },
              "health_path": {
                "type": "string",
                "default": "/api/tags"
              },
              "unload_timeout_s": {
                "type": "number",
                "default": 60.0
              },
              "systemd_unit": {
                "type": "string",
                "default": "ollama.service"
              },
              "tags_cache_ttl_s": {
                "type": "number",
                "default": 30.0
              },
              "control_headers": {
                "type": "object",
                "additionalProperties": true
              }
            },
            "additionalProperties": true,
            "required": [
              "type"
            ]
          },
          {
            "type": "object",
            "properties": {
              "type": {
                "const": "generic_process"
              },
              "enabled": {
                "type": "boolean",
                "default": true
              },
              "base_url": {
                "type": "string",
                "default": ""
              },
              "start_cmd": {
                "anyOf": [
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  {
                    "type": "string"
                  }
                ]
              },
              "env": {
                "type": "object",
                "additionalProperties": true
              },
              "cwd": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "ready_path": {
                "type": "string",
                "default": "/health"
              },
              "ready_check": {
                "type": "string",
                "default": ""
              },
              "start_timeout_s": {
                "type": "number",
                "default": 300.0
              },
              "stop_signal": {
                "type": "string",
                "default": "SIGTERM"
              },
              "stop_timeout_s": {
                "type": "number",
                "default": 30.0
              },
              "process_pattern": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "log_file": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "control_headers": {
                "type": "object",
                "additionalProperties": true
              },
              "discover_models": {
                "type": "boolean",
                "default": false
              },
              "served_models": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "tags_cache_ttl_s": {
                "type": "number",
                "default": 30.0
              }
            },
            "additionalProperties": true,
            "required": [
              "type"
            ]
          },
          {
            "type": "object",
            "properties": {
              "type": {
                "const": "api_swap"
              },
              "enabled": {
                "type": "boolean",
                "default": true
              },
              "base_url": {
                "type": "string",
                "default": ""
              },
              "health_path": {
                "type": "string",
                "default": "/v1/models"
              },
              "ready_check": {
                "type": "string",
                "default": ""
              },
              "unload_path": {
                "type": "string",
                "default": ""
              },
              "unload_method": {
                "type": "string",
                "default": "POST"
              },
              "unload_body": {
                "type": "object",
                "additionalProperties": true
              },
              "load_path": {
                "type": "string",
                "default": ""
              },
              "load_method": {
                "type": "string",
                "default": "POST"
              },
              "load_body": {
                "type": "object",
                "additionalProperties": true
              },
              "load_timeout_s": {
                "type": "number",
                "default": 120.0
              },
              "loaded_path": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "loaded_models_key": {
                "type": "string",
                "default": "models"
              },
              "loaded_name_key": {
                "type": "string",
                "default": "name"
              },
              "loaded_filter": {
                "type": "string",
                "default": ""
              },
              "loaded_id_key": {
                "type": "string",
                "default": ""
              },
              "unload_timeout_s": {
                "type": "number",
                "default": 60.0
              },
              "systemd_unit": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "tags_cache_ttl_s": {
                "type": "number",
                "default": 30.0
              },
              "control_headers": {
                "type": "object",
                "additionalProperties": true
              }
            },
            "additionalProperties": true,
            "required": [
              "type"
            ]
          }
        ]
      }
    },
    "models": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "engine": {
            "type": "string"
          },
          "display_name": {
            "type": "string"
          },
          "context_length": {
            "type": "integer",
            "default": 131072
          },
          "disable_thinking_below_max_tokens": {
            "anyOf": [
              {
                "type": "integer",
                "minimum": 1
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Inject chat_template_kwargs.enable_thinking=false on chat requests whose max_tokens is below this, so a small budget isn't eaten by the reasoning channel. null/omitted = off."
          }
        },
        "required": [
          "id",
          "engine"
        ],
        "additionalProperties": true
      }
    },
    "discover": {
      "type": "object",
      "description": "Optional global model-discovery settings. Absent or omitted = all defaults (discovery off). Discovery augments the static models: list and is entirely opt-in per engine via discover_models: true.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "augment_only": {
          "type": "boolean",
          "default": true
        },
        "collision": {
          "type": "string",
          "enum": [
            "config_order",
            "prefer_up"
          ],
          "default": "config_order"
        },
        "port_probe": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
