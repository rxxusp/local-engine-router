#!/usr/bin/env python3
"""Thin shim for the ``routerctl`` CLI.

The real implementation lives in :mod:`router.cli` so it ships inside the
package (and is exposed as a console-script entry point in pyproject.toml).
This script keeps ``./routerctl`` working from a checkout.
"""

import sys
from pathlib import Path

# Allow running ./routerctl directly from a checkout where the `router`
# package sits next to this script but isn't installed.
sys.path.insert(0, str(Path(__file__).resolve().parent))

from router.cli import main

if __name__ == "__main__":
    main()
